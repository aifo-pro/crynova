APP_NAME=Crynova
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Production: use MySQL/MariaDB on VPS
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=crynova
DB_USERNAME=crynova
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ── Crynova payment gateway ──────────────────────────────────────────
INVOICE_TTL_MINUTES=30
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_ATTEMPTS=5

# Bitcoin Core RPC
BTC_NODE_URL=http://127.0.0.1:8332
BTC_NODE_USER=rpcuser
BTC_NODE_PASS=
BTC_NETWORK=mainnet
BTC_CONFIRMATIONS=3

# Ethereum / Infura / Alchemy
ETH_NODE_URL=https://mainnet.infura.io/v3/YOUR_KEY
ETH_CHAIN_ID=1
ETH_CONFIRMATIONS=12
ETHERSCAN_API_KEY=
ETH_EXPLORER_URL=https://api.etherscan.io/api
BSCSCAN_API_KEY=
BSC_EXPLORER_URL=https://api.bscscan.com/api
BSC_CONFIRMATIONS=15

# HD account xpubs (optional — prefer Admin → Settings → Blockchain wallets)
# Account-level keys, e.g. BTC m/84'/0'/0', ETH m/44'/60'/0'
HD_XPUB_BTC=
HD_XPUB_LTC=
HD_XPUB_DOGE=
HD_XPUB_ETH=
HD_XPUB_TRON=

# Tron
TRON_NODE_URL=https://api.trongrid.io
TRON_API_KEY=
TRX_CONFIRMATIONS=20

# Litecoin
LTC_NODE_URL=http://127.0.0.1:9332
LTC_NODE_USER=rpcuser
LTC_NODE_PASS=
LTC_CONFIRMATIONS=6

# Dogecoin
DOGE_NODE_URL=http://127.0.0.1:22555
DOGE_NODE_USER=rpcuser
DOGE_NODE_PASS=
DOGE_CONFIRMATIONS=6
